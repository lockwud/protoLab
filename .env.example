# ---- Database (required) ----
# Local Postgres example. See README for setup instructions.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/protolab?schema=public"

# ---- Auth (required) ----
# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# ---- AI Prototype Assistant / Planning Engine / Documentation Generator (optional) ----
# Leave blank to disable AI features gracefully (the UI will show a friendly message).
CLAUDE_API_KEY=""
GEMINI_API_KEY=""

# ---- GitHub Integration (optional) ----
# Leave blank to disable GitHub features gracefully.
GITHUB_TOKEN=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
