// NOTE: This schema is the canonical source of truth for the database
// structure. In this build sandbox, `prisma generate` / `migrate dev` cannot
// reach binaries.prisma.sh (blocked by sandbox network policy), so the app's
// data layer talks to Postgres via `pg` directly against prisma/init.sql
// (hand-derived from this exact schema). On a normal machine with internet
// access, run `npx prisma generate` and `npx prisma migrate dev` as usual --
// see README "Using real Prisma Client" section.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum NotificationType {
  INFO
  ASSIGNMENT
  FEEDBACK
  MILESTONE
  SYSTEM
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(STUDENT)
  avatarUrl     String?
  bio           String?
  githubUsername String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  coursesTeaching   Course[]           @relation("CourseLecturer")
  enrollments       Enrollment[]
  submissions       Submission[]
  projects          Project[]
  feedbackGiven     Feedback[]         @relation("FeedbackAuthor")
  milestones        Milestone[]
  notifications     Notification[]
  documents         Document[]
  repositoryEntries InnovationRepository[] @relation("RepoAuthor")
  notificationSettings UserNotificationSettings?

  @@index([email])
}

model UserNotificationSettings {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedbackNotifications   Boolean  @default(true)
  milestoneNotifications  Boolean  @default(true)
  taskNotifications       Boolean  @default(false)
  githubIntegration       Boolean  @default(false)
  auditMode               Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @default(now()) @updatedAt
}

model Course {
  id          String   @id @default(cuid())
  title       String
  code        String   @unique
  description String?
  lecturerId  String
  lecturer    User     @relation("CourseLecturer", fields: [lecturerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  enrollments Enrollment[]
  assignments Assignment[]
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  student   User             @relation(fields: [studentId], references: [id])
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id])
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())

  @@unique([studentId, courseId])
}

model Assignment {
  id          String           @id @default(cuid())
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id])
  title       String
  description String
  status      AssignmentStatus @default(DRAFT)
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @default(now()) @updatedAt

  submissions Submission[]
  projects    Project[]
}

model Submission {
  id           String           @id @default(cuid())
  assignmentId String
  assignment   Assignment       @relation(fields: [assignmentId], references: [id])
  studentId    String
  student      User             @relation(fields: [studentId], references: [id])
  content      String
  fileUrl      String?
  status       SubmissionStatus @default(NOT_SUBMITTED)
  grade        Float?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  feedback     Feedback[]

  @@unique([assignmentId, studentId])
}

model Project {
  id            String   @id @default(cuid())
  title         String
  summary       String
  problemStatement String?
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  assignmentId  String?
  assignment    Assignment? @relation(fields: [assignmentId], references: [id])
  githubRepoUrl String?
  status        String   @default("PLANNING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  milestones    Milestone[]
  documents     Document[]
  feedback      Feedback[]
  aiSessions    AiSession[]
  repositoryEntry InnovationRepository?
  labWorkspace  LabWorkspace?
}

model Milestone {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id])
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  ownerId     String
  owner       User            @relation(fields: [ownerId], references: [id])
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
}

model Feedback {
  id           String      @id @default(cuid())
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])
  submissionId String?
  submission   Submission? @relation(fields: [submissionId], references: [id])
  authorId     String
  author       User        @relation("FeedbackAuthor", fields: [authorId], references: [id])
  content      String
  rating       Int?
  createdAt    DateTime    @default(now())
}

model Document {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  title     String
  type      String   @default("REPORT")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AiSession {
  id        String   @id @default(cuid())
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  prompt    String
  response  String
  provider  String   @default("claude")
  createdAt DateTime @default(now())
}

model InnovationRepository {
  id          String   @id @default(cuid())
  projectId   String   @unique
  project     Project  @relation(fields: [projectId], references: [id])
  authorId    String
  author      User     @relation("RepoAuthor", fields: [authorId], references: [id])
  featured    Boolean  @default(false)
  tags        String[]
  publishedAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType @default(INFO)
  title     String
  message   String
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
}

model LabWorkspace {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  mode      String   @default("NETWORKING")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  nodes       LabNode[]
  connections LabConnection[]
  validations LabValidation[]
  simulations LabSimulation[]
}

model ComponentInventory {
  id          String   @id
  name        String
  category    String
  kind        String
  description String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  nodes LabNode[]
}

model LabNode {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   LabWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  componentId String?
  component   ComponentInventory? @relation(fields: [componentId], references: [id])
  label       String
  type        String
  x           Float    @default(80)
  y           Float    @default(80)
  config      Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  outgoingConnections LabConnection[] @relation("SourceNode")
  incomingConnections LabConnection[] @relation("TargetNode")

  @@index([workspaceId])
}

model LabConnection {
  id            String   @id @default(cuid())
  workspaceId   String
  workspace     LabWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceNodeId  String
  sourceNode    LabNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId  String
  targetNode    LabNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  label         String?
  connectionType String @default("ethernet")
  config        Json    @default("{}")
  createdAt     DateTime @default(now())

  @@index([workspaceId])
}

model LabValidation {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   LabWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status      String
  issues      Json     @default("[]")
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}

model LabSimulation {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   LabWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  status      String
  summary     String
  traces      Json     @default("[]")
  metrics     Json     @default("{}")
  createdAt   DateTime @default(now())

  @@index([workspaceId])
}
